generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String     @id @default(uuid())
  phone          String     @unique
  name           String?
  createdAt      DateTime   @default(now())
  createdDebts   Debt[]     @relation("CreatorDebts")
  counterDebts   Debt[]     @relation("CounterpartyDebts")
  auditLogs      AuditLog[]
}

model Debt {
  id                    String     @id @default(uuid())
  amount                Float
  reason                String?
  dueDate               String     
  status                String     @default("pending") 
  creatorId             String
  creator               User       @relation("CreatorDebts", fields: [creatorId], references: [id])
  counterpartyId        String
  counterparty          User       @relation("CounterpartyDebts", fields: [counterpartyId], references: [id])
  creatorRole           String     
  creatorConfirmed      Boolean    @default(true)
  counterpartyConfirmed Boolean    @default(false)
  closeRequestedBy      String?    
  createdAt             DateTime   @default(now())
  confirmedAt           DateTime?
  closedAt              DateTime?
  auditLogs             AuditLog[]
}

model AuditLog {
  id        String   @id @default(uuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  timestamp DateTime @default(now())
  metadata  String?  @default("{}")
}

model Otp {
  phone     String   @id
  code      String
  expiresAt DateTime
}
